{
    "include": ["./typed-router.d.ts", "resources/js/**/*.ts", "resources/js/**/*.tsx", "resources/js/**/*.d.ts", "resources/js/**/*.vue"],
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        // this enables stricter inference for data properties on `this`
        "strict": true,
        // "allowJs": true,
        // "noImplicitAny": false,
        "jsx": "preserve",
        "moduleResolution": "Bundler",
        "types": ["vite/client"],
        "paths": {
            "@/*": ["./resources/js/*"]
        },
        "allowSyntheticDefaultImports": true
    },

    "vueCompilerOptions": {
        "plugins": ["vue-router/volar/sfc-route-blocks", "vue-router/volar/sfc-typed-router"]
    }
}
